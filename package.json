{
	"name": "n8n-nodes-chitchase",
	"version": "0.1.1",
	"description": "n8n community node for ChitChase — WhatsApp message templates, CRUD, send, and broadcast.",
	"license": "MIT",
	"homepage": "https://chitchase.com",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"chitchase",
		"whatsapp",
		"templates"
	],
	"author": {
		"name": "ChitChase"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitchase/n8n-node-chitchase.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ChitChaseApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ChitChase/ChitChase.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
